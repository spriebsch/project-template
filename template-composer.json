{
  "name": "spriebsch/project-template",
  "description": "A simple template for new projects.",
  "type": "project",
  "require": {
    "php": ">=8.5"
  },
  "require-dev": {
  },
  "autoload": {
    "classmap": [
      "src"
    ]
  },
  "autoload-dev": {
    "classmap": [
      "tests"
    ]
  },
  "scripts": {
    "clean": "rm -rf build",
    "fix-phpstorm": [
      "if [ ! -f \"phpunit.phar\" ]; then cp /usr/local/bin/phpunit phpunit.phar; fi"
    ],
  }
}
